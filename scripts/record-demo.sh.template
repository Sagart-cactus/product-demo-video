#!/usr/bin/env bash
# record-demo.sh — Generated by /demo-video (Claude Code plugin)
# Project: {{PROJECT_NAME}}
#
# This script records each scene of your demo and saves the raw recordings
# to the Remotion project's public/recordings/ directory.
#
# Run this BEFORE `npx remotion render`.
#
# Requirements:
#   - asciinema  (for terminal scenes): brew install asciinema
#   - agg        (for .cast → .mp4):    cargo install --git https://github.com/asciinema/agg
#   - ffmpeg     (for video conversion): brew install ffmpeg
#   - node / npx (for browser scenes):  pre-installed with Node.js
#   - Playwright (for browser scenes):  npx playwright install

set -euo pipefail

REMOTION_DIR="$(cd "$(dirname "$0")/.." && pwd)"
RECORDINGS_DIR="$REMOTION_DIR/public/recordings"
SCRIPTS_DIR="$REMOTION_DIR/scripts"

mkdir -p "$RECORDINGS_DIR"

echo ""
echo "============================================"
echo "  Product Demo Video — Recording Script"
echo "  Project: {{PROJECT_NAME}}"
echo "============================================"
echo ""

# ─────────────────────────────────────────────
# SCENE 1: {{SCENE_1_TITLE}} (type: terminal)
# ─────────────────────────────────────────────
echo "──────────────────────────────────────────────"
echo "SCENE 1 of {{SCENE_COUNT}}: {{SCENE_1_TITLE}}"
echo "──────────────────────────────────────────────"
echo "What to demo: {{SCENE_1_DESCRIPTION}}"
echo ""
echo "When the recording starts:"
echo "  {{SCENE_1_INSTRUCTIONS}}"
echo ""
echo "Press ENTER to start recording (CTRL+D to stop)..."
read -r
asciinema rec \
  --overwrite \
  --title "{{SCENE_1_TITLE}}" \
  "$RECORDINGS_DIR/scene-1.cast"

echo "Converting recording to MP4..."
"$SCRIPTS_DIR/convert-cast.sh" \
  "$RECORDINGS_DIR/scene-1.cast" \
  "$RECORDINGS_DIR/scene-1.mp4"

echo "Scene 1 done."
echo ""

# ─────────────────────────────────────────────
# SCENE 2: {{SCENE_2_TITLE}} (type: browser)
# ─────────────────────────────────────────────
echo "──────────────────────────────────────────────"
echo "SCENE 2 of {{SCENE_COUNT}}: {{SCENE_2_TITLE}}"
echo "──────────────────────────────────────────────"
echo "What to demo: {{SCENE_2_DESCRIPTION}}"
echo ""
echo "Recording browser session with Playwright..."

# Inline Playwright Node.js script for browser scene recording
node - <<'PLAYWRIGHT_SCRIPT'
const { chromium } = require('playwright');
const path = require('path');

(async () => {
  const recordingsDir = path.join(__dirname, '..', 'public', 'recordings');
  const browser = await chromium.launch({ headless: false });
  const context = await browser.newContext({
    recordVideo: {
      dir: recordingsDir,
      size: { width: 1920, height: 1080 },
    },
    viewport: { width: 1920, height: 1080 },
  });

  const page = await context.newPage();

  // ── BEGIN DEMO ACTIONS ─────────────────────────
  // {{SCENE_2_PLAYWRIGHT_ACTIONS}}
  await page.goto('{{SCENE_2_URL}}');
  await page.waitForTimeout(2000);
  // ── END DEMO ACTIONS ───────────────────────────

  await context.close();
  await browser.close();

  // Rename the recorded .webm to a known filename
  const fs = require('fs');
  const files = fs.readdirSync(recordingsDir).filter(f => f.endsWith('.webm'));
  if (files.length > 0) {
    const latest = files.sort((a, b) =>
      fs.statSync(path.join(recordingsDir, b)).mtime - fs.statSync(path.join(recordingsDir, a)).mtime
    )[0];
    fs.renameSync(
      path.join(recordingsDir, latest),
      path.join(recordingsDir, 'scene-2.webm')
    );
    console.log('Saved: scene-2.webm');
  }
})();
PLAYWRIGHT_SCRIPT

# Convert webm → mp4
echo "Converting browser recording to MP4..."
ffmpeg -y \
  -i "$RECORDINGS_DIR/scene-2.webm" \
  -c:v libx264 \
  -pix_fmt yuv420p \
  -movflags faststart \
  "$RECORDINGS_DIR/scene-2.mp4"

echo "Scene 2 done."
echo ""

# ─────────────────────────────────────────────
# ALL DONE
# ─────────────────────────────────────────────
echo "============================================"
echo "  All recordings complete!"
echo ""
echo "  Next steps:"
echo "  1. cd $REMOTION_DIR"
echo "  2. npx remotion studio     # preview the video"
echo "  3. npx remotion render DemoVideo output/demo.mp4"
echo "============================================"
